---
import { projects } from "../data/projects";
---

<section
  id="project"
  class="relative py-32 bg-background-dark text-white overflow-hidden"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none">
    <div class="hero-pattern w-full h-full"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="mb-20 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-white/10 pb-8">
      <div>
        <span class="text-secondary text-[10px] font-bold tracking-[0.3em] uppercase block mb-3">Portfolio</span>
        <h2 class="font-display text-4xl md:text-6xl text-white leading-tight">
          Contract <span class="font-serif italic text-secondary">Installations</span>
        </h2>
      </div>
      <p class="font-sans text-xs uppercase tracking-widest text-white/50 max-w-xs text-left md:text-right leading-relaxed">
        Custom furniture systems engineered for high-traffic environments, healthcare facilities, and luxury hospitality.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        projects.map((project) => (
          <a
            href={`/project/${project.slug}`}
            class="group block bg-background-dark border border-white/10 hover:border-secondary/35 transition-all duration-500 overflow-hidden shadow-sm"
          >
            <!-- Project Thumbnail -->
            <div class="aspect-[4/3] w-full overflow-hidden bg-white/5 relative">
              <img
                src={project.img}
                alt={project.name}
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-background-dark/25 group-hover:bg-background-dark/10 transition-colors duration-500" />
            </div>

            <!-- Project Info -->
            <div class="p-8 flex flex-col justify-between h-[220px]">
              <div>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-secondary text-[9px] font-bold tracking-widest uppercase">
                    {project.client}
                  </span>
                  <span class="text-white/40 text-[10px] font-mono">
                    {project.year}
                  </span>
                </div>
                <h3 class="font-display text-xl font-bold tracking-wide text-white group-hover:text-secondary transition-colors mb-3">
                  {project.name}
                </h3>
                <p class="text-white/60 text-xs line-clamp-2 leading-relaxed font-sans font-light">
                  {project.description}
                </p>
              </div>

              <!-- Button CTA -->
              <div class="flex items-center gap-2 text-secondary text-[9px] font-bold uppercase tracking-[0.2em] group-hover:gap-4 transition-all">
                <span>View Details</span>
                <span class="material-icons-outlined text-xs">east</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Bottom Banner Info -->
    <div class="mt-24 py-10 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="max-w-xl text-center md:text-left">
        <h4 class="font-display text-xl font-bold text-white mb-2">Need custom solutions for your space?</h4>
        <p class="text-white/60 text-xs leading-relaxed font-sans font-light">
          We collaborate with architects, interior designers, and commercial stakeholders to manufacture standardized or custom wood furnishings at contract scale.
        </p>
      </div>
      <a
        href="https://wa.me/81127005688"
        class="bg-secondary text-background-dark px-10 py-4 text-[10px] font-bold uppercase tracking-[0.25em] hover:bg-secondary/90 transition-all font-sans"
      >
        Inquire Now
      </a>
    </div>
  </div>
</section>
