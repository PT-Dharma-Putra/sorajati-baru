</div>

<script>
  function initScrollIndicator() {
    const sections = document.querySelectorAll("section[id]");
    const dots = document.querySelectorAll(".scroll-dot");

    const handleScroll = () => {
      let currentSectionId = "";
      const scrollPosition = window.scrollY + window.innerHeight / 3;

      sections.forEach((section) => {
        if (section instanceof HTMLElement) {
          const top = section.offsetTop;
          const height = section.offsetHeight;
          if (scrollPosition >= top && scrollPosition < top + height) {
            currentSectionId = section.id;
          }
        }
      });

      dots.forEach((dot) => {
        if (dot instanceof HTMLElement) {
          const sectionId = dot.dataset.section;
          const innerSpan = dot.querySelector("span");
          if (sectionId === currentSectionId) {
            innerSpan?.classList.add("bg-secondary", "scale-[1.8]", "shadow-md");
            innerSpan?.classList.remove("bg-primary/40");
          } else {
            innerSpan?.classList.remove("bg-secondary", "scale-[1.8]", "shadow-md");
            innerSpan?.classList.add("bg-primary/40");
          }
        }
      });
    };

    window.addEventListener("scroll", handleScroll);
    handleScroll();
  }

  document.addEventListener("DOMContentLoaded", initScrollIndicator);
  document.addEventListener("astro:page-load", initScrollIndicator);
</script>
