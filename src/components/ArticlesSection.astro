---
import { articles } from "../data/articles";
const latestArticles = articles.slice(0, 3);
---

<section id="articles" class="py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section Header -->
    <div
      class="mb-20 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-primary/10 pb-8"
    >
      <div>
        <span
          class="text-primary text-[10px] font-bold tracking-[0.3em] uppercase block mb-3"
          >Articles & Insights</span
        >
        <h2
          class="font-display text-4xl md:text-6xl text-background-dark leading-tight"
        >
          Our Latest <span class="font-serif italic text-primary">Journal</span>
        </h2>
      </div>
      <a
        href="/articles"
        class="inline-flex items-center gap-2 text-[11px] font-bold tracking-[0.2em] text-primary hover:gap-4 transition-all uppercase"
      >
        <span>View All Articles</span>
        <span class="material-icons-outlined text-sm">east</span>
      </a>
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        latestArticles.map((article) => (
          <a
            href={`/articles/${article.slug}`}
            class="group block bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-zinc-100 flex flex-col h-full"
          >
            <div class="relative h-64 overflow-hidden">
              <img
                src={article.img}
                alt={article.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-8 flex flex-col flex-grow">
              <div class="flex items-center gap-4 mb-4">
                <span
                  class="text-xs font-semibold text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full"
                  >{article.category}</span
                >
                <span class="text-xs text-slate-400 font-medium font-mono"
                  >{article.date}</span
                >
              </div>
              <h3
                class="font-display text-2xl font-bold text-slate-800 mb-4 leading-tight group-hover:text-primary transition-colors"
              >
                {article.title}
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">
                {article.summary}
              </p>
              <div
                class="flex items-center gap-2 text-primary font-medium text-sm group/btn mt-auto"
              >
                <span>Read Full Article</span>
                <span
                  class="material-icons-outlined text-sm transform group-hover/btn:translate-x-1 transition-transform"
                  >east</span
                >
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
