---
// Capabilities data
const services = [
  {
    icon: "design_services",
    title: "Tailored Customization",
    desc: "We co-create furniture systems tailored to specific client layouts, from size modifications to custom wood staining and fabric selections."
  },
  {
    icon: "precision_manufacturing",
    title: "Contract Scale Manufacturing",
    desc: "Supported by a specialized factory in Yogyakarta, we handle large volume productions for hotels, clinics, and commercial developments."
  },
  {
    icon: "nature_people",
    title: "Ethical Timber Sourcing",
    desc: "We prioritize certified sustainably sourced teak, mindi, and wadang wood, dried to optimal moisture content for ultimate stability."
  },
  {
    icon: "local_shipping",
    title: "Delivery & Installation",
    desc: "Our logistics team ensures secure shipping, handling, and on-site assembly to guarantee structural alignment and perfect finish."
  }
];
---

<section id="services" class="py-32 bg-[#FAF7F2] border-b border-primary/5">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="mb-20 text-center max-w-2xl mx-auto">
      <span class="text-primary text-[10px] font-bold tracking-[0.3em] uppercase block mb-3">Capabilities</span>
      <h2 class="font-display text-4xl md:text-6xl text-background-dark leading-tight mb-6">
        Contract <span class="font-serif italic text-primary">Capabilities</span>
      </h2>
      <p class="text-background-dark/70 text-xs md:text-sm leading-relaxed font-sans font-light">
        PT Sorajati Dharma offers standardized production processes and craftsmanship to deliver strong, comfortable, and high-value furniture for commercial and contract needs.
      </p>
    </div>

    <!-- Capabilities Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        services.map((item) => (
          <div class="bg-white border border-primary/10 p-8 flex flex-col justify-between h-[300px] shadow-sm hover:shadow-md transition-shadow">
            <div>
              <!-- Icon Circle -->
              <div class="w-12 h-12 border border-primary/20 flex items-center justify-center text-primary mb-6">
                <span class="material-icons-outlined text-2xl">{item.icon}</span>
              </div>
              <h3 class="font-display text-lg font-bold text-background-dark tracking-wide mb-3">
                {item.title}
              </h3>
              <p class="text-background-dark/70 text-[11px] leading-relaxed font-sans font-light">
                {item.desc}
              </p>
            </div>
            
            <div class="w-8 h-[1px] bg-primary/30"></div>
          </div>
        ))
      }
    </div>
  </div>
</section>
