<section
  id="home"
  class="relative w-full h-[80vh] min-h-[500px] md:h-[56.25vw] overflow-hidden bg-background-dark"
>
  <!-- Swiper Slider -->
  <div class="swiper hero-slider absolute inset-0 z-0 h-full w-full">
    <div class="swiper-wrapper">
      <!-- Slide 1: Tokyo Exhibition (Image Only) -->
      <div
        class="swiper-slide relative h-full w-full flex items-center justify-center bg-background-dark"
      >
        <a
          href="https://wa.me/81128507788?text=Hello%20Sorajati%20Dharma,%20I'm%20inquiring%20about%20your%20booth%20at%20Interior%20Lifestyle%20Tokyo%202026."
          target="_blank"
          class="block w-full h-full cursor-pointer"
        >
          <img
            alt="Sorajati goes to Tokyo - Interior Lifestyle Tokyo 2026"
            class="w-full h-full object-contain object-center bg-background-dark"
            src="/images/tokyo-exhibition.png"
          />
        </a>
      </div>

      <!-- Slide 2: Exotic Wood Culture (Original Hero with Text Overlays) -->
      <div
        class="swiper-slide relative h-full w-full flex items-center justify-center"
      >
        <div class="absolute inset-0">
          <video
            autoplay
            loop
            muted
            playsinline
            poster="/images/hero-bg.png"
            class="w-full h-full object-cover scale-100 filter brightness-[0.8]"
          >
            <source src="/images/konten/3).%20Sorajati%20Video.mp4" type="video/mp4" />
            <img
              alt="Luxury Interior wood furniture"
              class="w-full h-full object-cover scale-100 filter brightness-[0.8]"
              src="/images/hero-bg.png"
            />
          </video>
          <div
            class="absolute inset-0 bg-gradient-to-b from-background-dark/25 via-background-dark/45 to-background-dark/20"
          >
          </div>
        </div>

        <div
          class="relative z-10 w-full max-w-5xl px-6 text-center mt-12 hero-slide-content"
        >
          <div
            class="inline-flex items-center gap-2 px-4 py-1.5 border border-secondary/30 bg-background-dark/40 backdrop-blur-md mb-8"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-secondary animate-pulse"
            ></span>
            <span
              class="text-[10px] font-bold text-secondary tracking-[0.3em] uppercase"
              >Exotic Wood Culture</span
            >
          </div>

          <h1
            class="font-display text-4xl md:text-8xl text-white mb-8 leading-[1.1] tracking-tight"
          >
            Javanese <span class="font-serif italic text-secondary">Java</span
            >,<br />
            Contemporary <span class="font-serif italic text-secondary"
              >Abode</span
            >
          </h1>

          <p
            class="text-sm md:text-lg text-white/80 mb-12 max-w-2xl mx-auto font-sans leading-relaxed tracking-wide font-light"
          >
            A subtle and simple reflection of Javanese wood culture
          </p>

          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <a
              href="#project"
              class="w-full sm:w-auto px-10 py-4 bg-primary text-white font-bold text-[10px] uppercase tracking-[0.25em] hover:bg-primary/95 transition-all shadow-md"
            >
              Explore Projects
            </a>
            <a
              href="https://wa.me/81128507788?text=Hello%20Sorajati%20Dharma,%20I'd%20like%20to%20inquire%20about%20your%20woodcraft%20collection."
              target="_blank"
              class="w-full sm:w-auto px-10 py-4 border border-white/20 text-white font-bold text-[10px] uppercase tracking-[0.25em] hover:bg-white hover:text-background-dark transition-all"
            >
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Swiper Pagination -->
    <div class="swiper-pagination !bottom-24 !left-1/2 !-translate-x-1/2 !z-20">
    </div>

    <!-- Navigation Arrows -->
    <button
      class="hero-swiper-prev absolute left-6 top-1/2 -translate-y-1/2 z-20 w-12 h-12 border border-white/20 hover:border-white text-white hover:bg-white/10 transition-all flex items-center justify-center hidden md:flex"
      aria-label="Previous slide"
    >
      <span class="material-icons-outlined">keyboard_arrow_left</span>
    </button>
    <button
      class="hero-swiper-next absolute right-6 top-1/2 -translate-y-1/2 z-20 w-12 h-12 border border-white/20 hover:border-white text-white hover:bg-white/10 transition-all flex items-center justify-center hidden md:flex"
      aria-label="Next slide"
    >
      <span class="material-icons-outlined">keyboard_arrow_right</span>
    </button>
  </div>

  <div
    class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 animate-bounce cursor-pointer opacity-50 hover:opacity-100 transition-opacity"
  >
    <a href="#about" class="text-white">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7 13l5 5 5-5M7 6l5 5 5-5"></path>
      </svg>
    </a>
  </div>
</section>

<!-- Swiper custom styling for premium feel -->
<style>
  :global(.hero-slider .swiper-pagination-bullet) {
    background: rgba(255, 255, 255, 0.3) !important;
    opacity: 1 !important;
    width: 24px !important;
    height: 3px !important;
    border-radius: 0 !important;
    transition: all 0.3s ease !important;
  }
  :global(.hero-slider .swiper-pagination-bullet-active) {
    background: #c59b27 !important; /* Gold */
    width: 48px !important;
  }

  /* Text reveal animation on slide active state */
  .hero-slide-content > * {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(.swiper-slide-active .hero-slide-content > *:nth-child(1)) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.2s;
  }
  :global(.swiper-slide-active .hero-slide-content > *:nth-child(2)) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.4s;
  }
  :global(.swiper-slide-active .hero-slide-content > *:nth-child(3)) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.6s;
  }
  :global(.swiper-slide-active .hero-slide-content > *:nth-child(4)) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.8s;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay, EffectFade } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/navigation";
  import "swiper/css/pagination";
  import "swiper/css/effect-fade";

  function initHeroSlider() {
    new Swiper(".hero-slider", {
      modules: [Navigation, Pagination, Autoplay, EffectFade],
      effect: "fade",
      fadeEffect: { crossFade: true },
      loop: true,
      autoplay: {
        delay: 6000,
        disableOnInteraction: false,
      },
      pagination: {
        el: ".hero-slider .swiper-pagination",
        clickable: true,
      },
      navigation: {
        nextEl: ".hero-swiper-next",
        prevEl: ".hero-swiper-prev",
      },
    });
  }

  // Handle load and page-transitions
  document.addEventListener("DOMContentLoaded", initHeroSlider);
  document.addEventListener("astro:page-load", initHeroSlider);
</script>
