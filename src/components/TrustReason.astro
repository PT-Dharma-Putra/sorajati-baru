<section id="trust" class="relative py-32 overflow-hidden bg-[#FAF7F2]">
  <div
    class="relative z-10 max-w-7xl mx-auto px-6 flex flex-col lg:flex-row items-center gap-16 lg:gap-24"
  >
    <!-- Left Column: Accordion Details -->
    <div class="flex-1 space-y-10 w-full">
      <div>
        <span class="text-primary text-[10px] font-bold tracking-[0.3em] uppercase block mb-3">Guarantees</span>
        <h2
          class="font-display text-4xl md:text-5xl text-background-dark leading-tight"
        >
          Why Choose <span class="font-serif italic text-primary">Sorajati Dharma Furniture</span>?
        </h2>
      </div>

      <div class="space-y-4 max-w-xl">
        {
          [
            {
              icon: "verified",
              title: "Guaranteed Product Quality",
              items: [
                "Utilizing seasoned, premium teak and wadang wood ensuring lifetime stability.",
                "High-density royal foam (D26, D32) that holds resilience and shape for years.",
                "Flawless joinery, double-dowel reinforcing, and premium PU duco finishes."
              ]
            },
            {
              icon: "local_shipping",
              title: "Committed Delivery & Deadlines",
              items: [
                "Strict scheduling and progress reporting from the Sleman factory.",
                "Direct communication on timelines to respect your project schedules."
              ]
            },
            {
              icon: "factory",
              title: "Direct Production Pricing",
              items: [
                "No intermediate broker fees, offering direct factory competitive rates.",
                "Tighter in-house quality control and adaptable bespoke requests."
              ]
            },
            {
              icon: "design_services",
              title: "Bespoke Adaptability",
              items: [
                "Total customization of size dimensions, colors, wood species, and fabrics.",
                "Engineered to blend with hotels, clinics, cafes, or executive spaces."
              ]
            }
          ].map((item, index) => (
            <div class="bg-white border border-primary/10 text-background-dark p-6 cursor-pointer hover:border-primary/30 transition-all duration-300 accordion-item">
              <div class="flex items-center justify-between pointer-events-none">
                <div class="flex items-center gap-5">
                  <div class="shrink-0 text-primary">
                    <span class="material-icons-outlined text-3xl">
                      {item.icon}
                    </span>
                  </div>
                  <p class="font-display font-bold text-base text-background-dark tracking-wide">{item.title}</p>
                </div>
                <span class="material-icons-outlined text-primary/60 transform transition-transform duration-300 accordion-icon">
                  expand_more
                </span>
              </div>
              <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out accordion-content pointer-events-none">
                <div class="overflow-hidden">
                  <ul class="text-xs text-background-dark/75 space-y-2 list-disc pl-14 pt-4 marker:text-primary/45 leading-relaxed font-sans font-light">
                    {item.items.map((listItem) => (
                      <li>{listItem}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <script>
        document.addEventListener("astro:page-load", () => {
          setupAccordion();
        });
        document.addEventListener("DOMContentLoaded", () => {
          setupAccordion();
        });

        function setupAccordion() {
          const items = document.querySelectorAll(".accordion-item");

          items.forEach((item) => {
            // Remove existing listener to be safe
            const newItem = item.cloneNode(true);
            if (item.parentNode) {
              item.parentNode.replaceChild(newItem, item);
            }

            newItem.addEventListener("click", () => {
              const allItems = document.querySelectorAll(".accordion-item");
              allItems.forEach((otherItem) => {
                if (otherItem !== newItem) {
                  otherItem.classList.remove("active", "border-primary");
                  otherItem.classList.add("border-primary/10");
                  const content = otherItem.querySelector(".accordion-content");
                  if (content) {
                    content.classList.remove("grid-rows-[1fr]");
                    content.classList.add("grid-rows-[0fr]");
                  }
                  const icon = otherItem.querySelector(".accordion-icon");
                  if (icon) {
                    icon.classList.remove("rotate-180");
                  }
                }
              });

              const content = newItem.querySelector(".accordion-content");
              const icon = newItem.querySelector(".accordion-icon");

              if (newItem instanceof HTMLElement) {
                if (newItem.classList.contains("active")) {
                  newItem.classList.remove("active", "border-primary");
                  newItem.classList.add("border-primary/10");
                  content?.classList.remove("grid-rows-[1fr]");
                  content?.classList.add("grid-rows-[0fr]");
                  icon?.classList.remove("rotate-180");
                } else {
                  newItem.classList.add("active", "border-primary");
                  newItem.classList.remove("border-primary/10");
                  content?.classList.remove("grid-rows-[0fr]");
                  content?.classList.add("grid-rows-[1fr]");
                  icon?.classList.add("rotate-180");
                }
              }
            });
          });
        }
      </script>
    </div>

    <!-- Right Column: Asymmetric Editorial Image -->
    <div class="flex-1 w-full lg:w-1/2 relative flex items-stretch">
      <div
        class="relative w-full h-[450px] lg:h-auto min-h-[500px] overflow-hidden border border-primary/10 bg-white p-4 shadow-sm"
      >
        <img
          src="/trust_image.png"
          alt="Trust Us for Contract Manufacturing"
          class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
          loading="lazy"
        />
        <!-- Floating highlight badge -->
        <div class="absolute top-8 right-8 bg-[#1E1815] text-[#FAF7F2] py-4 px-6 border border-primary/15">
          <p class="text-[9px] font-bold tracking-[0.2em] uppercase">100% INDONESIAN</p>
          <p class="font-serif italic text-xs text-secondary mt-0.5">Woodcraft Quality</p>
        </div>
      </div>
    </div>
  </div>
</section>
