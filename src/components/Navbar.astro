<script>
  function initNav() {
    const navbar = document.getElementById("navbar");
    const navContainer = document.getElementById("nav-container");
    const menuToggle = document.getElementById("menu-toggle");
    const menuClose = document.getElementById("menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    // Scroll effect
    const handleScroll = () => {
      const brandTitle = document.getElementById("brand-title");
      const brandSub = document.getElementById("brand-sub");
      const navLinks = document.querySelectorAll(".nav-link");
      const inquiryBtn = document.getElementById("nav-inquiry-btn");

      if (window.scrollY > 50) {
        navbar?.classList.add(
          "top-4",
          "w-[90%]",
          "max-w-5xl",
          "rounded-full",
          "left-1/2",
          "-translate-x-1/2",
          "shadow-lg",
          "bg-white/80",
          "backdrop-blur-md",
          "py-2.5",
          "border",
          "border-primary/10"
        );
        navbar?.classList.remove(
          "top-0",
          "w-full",
          "left-0",
          "bg-transparent",
          "border-b",
          "border-white/10",
          "py-4",
          "backdrop-blur-none"
        );
        navContainer?.classList.remove("py-4");
        navContainer?.classList.add("py-1");

        // Brand colors to dark
        brandTitle?.classList.remove("text-white");
        brandTitle?.classList.add("text-background-dark");
        brandSub?.classList.remove("text-secondary/90");
        brandSub?.classList.add("text-primary/70");

        // Links to dark
        navLinks.forEach((link) => {
          link.classList.remove("text-white/90");
          link.classList.add("text-background-dark/80");
        });

        // Inquiry Button to dark outline
        inquiryBtn?.classList.remove("border-white", "text-white");
        inquiryBtn?.classList.add("border-primary", "text-primary");

        // Menu Toggle to dark
        menuToggle?.classList.remove("text-white");
        menuToggle?.classList.add("text-primary");
      } else {
        navbar?.classList.remove(
          "top-4",
          "w-[90%]",
          "max-w-5xl",
          "rounded-full",
          "left-1/2",
          "-translate-x-1/2",
          "shadow-lg",
          "bg-white/80",
          "backdrop-blur-md",
          "py-2.5",
          "border",
          "border-primary/10"
        );
        navbar?.classList.add(
          "top-0",
          "w-full",
          "left-0",
          "bg-transparent",
          "border-b",
          "border-white/10",
          "py-4",
          "backdrop-blur-none"
        );
        navContainer?.classList.remove("py-1");
        navContainer?.classList.add("py-4");

        // Brand colors back to light
        brandTitle?.classList.add("text-white");
        brandTitle?.classList.remove("text-background-dark");
        brandSub?.classList.add("text-secondary/90");
        brandSub?.classList.remove("text-primary/70");

        // Links back to light
        navLinks.forEach((link) => {
          link.classList.add("text-white/90");
          link.classList.remove("text-background-dark/80");
        });

        // Inquiry Button back to light outline
        inquiryBtn?.classList.add("border-white", "text-white");
        inquiryBtn?.classList.remove("border-primary", "text-primary");

        // Menu Toggle back to white
        menuToggle?.classList.add("text-white");
        menuToggle?.classList.remove("text-primary");
      }
    };

    window.addEventListener("scroll", handleScroll);
    handleScroll(); // Initial check

    function openMenu() {
      mobileMenu?.classList.remove("translate-x-full");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      mobileMenu?.classList.add("translate-x-full");
      document.body.style.overflow = "";
    }

    menuToggle?.addEventListener("click", openMenu);
    menuClose?.addEventListener("click", closeMenu);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  // Handle initialization on both standard load and Astro's view transitions if enabled
  document.addEventListener("DOMContentLoaded", initNav);
  document.addEventListener("astro:page-load", initNav);
</script>
