---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Articles | KJAS">
  <Navbar />
  <main class="pt-32 pb-24 bg-zinc-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16 text-center">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-primary mb-6 tracking-tight">
          Articles
        </h1>
        <p class="text-slate-600 max-w-2xl mx-auto text-lg leading-relaxed">
          Stay updated with the latest news, insights, and inspirations from Kartika Jaya Ananda Sejahtera.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Article Card 1 -->
        <a href="/articles/fabric-vs-leather-sofas" class="group block bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-zinc-100 flex flex-col h-full">
          <div class="relative h-64 overflow-hidden">
            <img 
              src="/images/article/fabric-vs-leather-hero.png" 
              alt="Fabric vs Leather Sofas" 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-xs font-semibold text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full">Guides</span>
              <span class="text-xs text-slate-400 font-medium font-mono">13 APR 2026</span>
            </div>
            <h3 class="font-display text-2xl font-bold text-slate-800 mb-4 leading-tight group-hover:text-primary transition-colors">
              Fabric vs. Leather Sofas: Which Best Suits Your Lifestyle?
            </h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">
              Choosing a sofa is more than just selecting a seat; it is a long-term investment in the comfort and aesthetics of your living space...
            </p>
            <div class="flex items-center gap-2 text-primary font-medium text-sm group/btn mt-auto">
              <span>Read Full Article</span>
              <span class="material-icons-outlined text-sm transform group-hover/btn:translate-x-1 transition-transform">east</span>
            </div>
          </div>
        </a>
      </div>
      
      <!-- Back to Home -->
       <div class="mt-20 flex justify-center">
        <a href="/#home" class="flex items-center gap-2 text-primary font-medium hover:gap-4 transition-all uppercase tracking-wide group">
          <span class="material-icons-outlined group-hover:-translate-x-1 transition-transform">west</span>
          <span>Back to Home</span>
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>
