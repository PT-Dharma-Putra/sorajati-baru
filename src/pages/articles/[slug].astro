---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { articles } from "../../data/articles";

export async function getStaticPaths() {
  return articles.map((article, index) => {
    const nextArticle = articles[(index + 1) % articles.length];
    return {
      params: { slug: article.slug },
      props: { article, nextArticleSlug: nextArticle.slug },
    };
  });
}

const { article, nextArticleSlug } = Astro.props;
---

<Layout title={`${article.title} | Sorajati Dharma Articles`}>
  <Navbar />
  
  <main class="pt-32 pb-24 bg-[#FAF7F2] min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      
      <!-- Back Link -->
      <div class="mb-10">
        <a
          href="/#articles"
          class="inline-flex items-center gap-2 text-primary font-medium hover:gap-4 transition-all uppercase tracking-widest text-xs"
        >
          <span class="material-icons-outlined text-sm">west</span>
          <span>Back to Articles</span>
        </a>
      </div>

      <!-- Article Header -->
      <div class="mb-12 border-b border-primary/10 pb-10">
        <div class="flex items-center gap-4 mb-4">
          <span
            class="text-xs font-semibold text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full"
            >{article.category}</span
          >
          <span class="text-xs text-slate-400 font-medium font-mono"
            >{article.date}</span
          >
        </div>
        <h1
          class="font-display text-4xl md:text-5xl font-bold text-background-dark leading-tight tracking-tight"
        >
          {article.title}
        </h1>
      </div>

      <!-- Feature Image -->
      <div class="relative h-[400px] md:h-[500px] overflow-hidden rounded-3xl shadow-md border border-primary/5 p-2 bg-white mb-16">
        <img
          src={article.img}
          alt={article.title}
          class="w-full h-full object-cover rounded-2xl"
        />
      </div>

      <!-- Article Content -->
      <article
        class="prose prose-slate max-w-none text-slate-700 leading-relaxed font-sans font-light space-y-6 text-justify"
        set:html={article.content}
      />

      <!-- Next Article Navigation -->
      <div class="mt-20 pt-10 border-t border-primary/10 flex justify-between items-center">
        <div></div>
        <a
          href={`/articles/${nextArticleSlug}`}
          class="bg-white border border-primary/10 px-6 py-3 rounded-none shadow-md text-background-dark hover:bg-primary hover:text-white transition-all duration-300 flex items-center gap-2 group"
        >
          <span class="text-[9px] font-bold tracking-[0.2em] uppercase"
            >Next Article</span
          >
          <span
            class="material-icons-outlined text-base group-hover:translate-x-1 transition-transform flex items-center justify-center"
            >arrow_forward</span
          >
        </a>
      </div>

    </div>
  </main>
  
  <Footer />
</Layout>
