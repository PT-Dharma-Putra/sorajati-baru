---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";

// Count stats
const totalProjects = projects.length;
const hospitalityCount = projects.filter(p => p.category === "Hospitality").length;
const healthcareCount = projects.filter(p => p.category === "Healthcare").length;
const fbCount = projects.filter(p => p.category === "Food & Beverage").length;
---

<Layout title="Sorajati Dharma Projects | Interactive Portfolio Explorer">
  <Navbar />
  <main class="pt-36 pb-24 bg-background-light min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
      
      <!-- Section Header -->
      <div class="mb-12 text-center max-w-3xl mx-auto">
        <span class="text-primary text-[10px] font-bold tracking-[0.3em] uppercase block mb-3">Interactive Portfolio</span>
        <h1 class="font-display text-4xl md:text-6xl text-background-dark leading-tight mb-6">
          Explore Our <span class="font-serif italic text-primary">Installations</span>
        </h1>
        <p class="text-background-dark/70 text-xs md:text-sm leading-relaxed font-sans font-light max-w-xl mx-auto">
          An interactive showcase of our customized, eco-friendly furnishings for rooms, dining areas, and lobbies—manufactured in Indonesia and exported globally for the hospitality, restaurant, and healthcare sectors.
        </p>
      </div>

      <!-- Stats Overview Bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10 max-w-4xl mx-auto border-y border-primary/10 py-6">
        <div class="text-center border-r border-primary/5 last:border-0">
          <span class="block text-2xl md:text-3xl font-display font-bold text-primary" id="stat-total">{totalProjects}</span>
          <span class="text-[9px] uppercase tracking-wider text-background-dark/50">Total Installations</span>
        </div>
        <div class="text-center border-r border-primary/5 last:border-0">
          <span class="block text-2xl md:text-3xl font-display font-bold text-secondary">{hospitalityCount}</span>
          <span class="text-[9px] uppercase tracking-wider text-background-dark/50">Hospitality & Living</span>
        </div>
        <div class="text-center border-r border-primary/5 last:border-0">
          <span class="block text-2xl md:text-3xl font-display font-bold text-primary">{healthcareCount}</span>
          <span class="text-[9px] uppercase tracking-wider text-background-dark/50">Healthcare</span>
        </div>
        <div class="text-center last:border-0">
          <span class="block text-2xl md:text-3xl font-display font-bold text-primary">{fbCount}</span>
          <span class="text-[9px] uppercase tracking-wider text-background-dark/50">Food & Beverage</span>
        </div>
      </div>

      <!-- Filters & Search Toolbar -->
      <div class="bg-white border border-primary/10 p-6 md:p-8 mb-12 flex flex-col md:flex-row gap-6 justify-between items-stretch md:items-center shadow-sm">
        
        <!-- Category Selector -->
        <div class="flex flex-wrap gap-2 items-center" id="category-filters">
          <button
            data-filter="all"
            class="filter-btn active px-4 py-2 text-[10px] font-bold uppercase tracking-wider transition-all duration-300 border border-primary/10 hover:border-primary bg-primary text-white"
          >
            All <span class="ml-1 text-[8px] opacity-75 font-mono">({totalProjects})</span>
          </button>
          <button
            data-filter="Hospitality"
            class="filter-btn px-4 py-2 text-[10px] font-bold uppercase tracking-wider transition-all duration-300 border border-primary/10 hover:border-primary text-background-dark/70 hover:text-primary"
          >
            Hospitality <span class="ml-1 text-[8px] opacity-75 font-mono">({hospitalityCount})</span>
          </button>
          <button
            data-filter="Healthcare"
            class="filter-btn px-4 py-2 text-[10px] font-bold uppercase tracking-wider transition-all duration-300 border border-primary/10 hover:border-primary text-background-dark/70 hover:text-primary"
          >
            Healthcare <span class="ml-1 text-[8px] opacity-75 font-mono">({healthcareCount})</span>
          </button>
          <button
            data-filter="Food & Beverage"
            class="filter-btn px-4 py-2 text-[10px] font-bold uppercase tracking-wider transition-all duration-300 border border-primary/10 hover:border-primary text-background-dark/70 hover:text-primary"
          >
            Food & Beverage <span class="ml-1 text-[8px] opacity-75 font-mono">({fbCount})</span>
          </button>
        </div>

        <!-- Real-time Search -->
        <div class="relative min-w-[260px] md:min-w-[320px]">
          <span class="material-icons-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-primary/40 text-lg">search</span>
          <input
            type="text"
            id="search-input"
            placeholder="Search name, location, furniture..."
            class="w-full bg-background-light border border-primary/10 px-10 py-2.5 text-xs text-background-dark placeholder-background-dark/40 focus:outline-none focus:border-primary transition-colors font-sans"
          />
          <button
            id="clear-search"
            class="absolute right-3.5 top-1/2 -translate-y-1/2 text-primary/40 hover:text-primary hidden"
            aria-label="Clear search"
          >
            <span class="material-icons-outlined text-base">close</span>
          </button>
        </div>

      </div>

      <!-- No Results State -->
      <div id="no-results" class="hidden text-center py-20 bg-white border border-primary/5 max-w-xl mx-auto shadow-sm">
        <span class="material-icons-outlined text-4xl text-primary/30 mb-4">info_outline</span>
        <h3 class="font-display text-xl font-bold text-background-dark mb-2">No installations found</h3>
        <p class="text-background-dark/60 text-xs mb-6 font-light max-w-sm mx-auto">
          We couldn't find any projects matching your current filters or search terms.
        </p>
        <button
          id="reset-filters"
          class="bg-primary text-white px-6 py-2.5 text-[9px] font-bold uppercase tracking-widest hover:bg-primary/95 transition-colors"
        >
          Reset All Filters
        </button>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">
        {
          projects.map((project) => (
            <a
              href={`/project/${project.slug}`}
              class="project-card group block bg-white border border-primary/10 hover:border-primary/35 transition-all duration-500 overflow-hidden shadow-sm animate-fade-in"
              data-category={project.category}
              data-name={project.name.toLowerCase()}
              data-client={project.client.toLowerCase()}
              data-location={project.location.toLowerCase()}
              data-furniture={project.furniture.join(" ").toLowerCase()}
            >
              <!-- Project Thumbnail -->
              <div class="aspect-[4/3] w-full overflow-hidden bg-background-dark/5 relative">
                <img
                  src={project.img}
                  alt={project.name}
                  class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-background-dark/10 group-hover:bg-transparent transition-colors duration-500" />
                
                <!-- Category Tag Overlay -->
                <span class="absolute top-4 left-4 bg-primary text-white text-[8px] font-bold tracking-widest uppercase px-3 py-1.5 shadow-sm">
                  {project.category}
                </span>
              </div>

              <!-- Project Info -->
              <div class="p-8 flex flex-col justify-between h-[230px]">
                <div>
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-primary text-[9px] font-bold tracking-widest uppercase">
                      {project.client}
                    </span>
                    <span class="text-background-dark/40 text-[10px] font-mono">
                      {project.year}
                    </span>
                  </div>
                  <h3 class="font-display text-xl font-bold tracking-wide text-background-dark group-hover:text-primary transition-colors mb-2">
                    {project.name}
                  </h3>
                  <!-- Location Info -->
                  <div class="flex items-center gap-1 text-[10px] text-background-dark/50 mb-3">
                    <span class="material-icons-outlined text-xs text-secondary">place</span>
                    <span>{project.location}</span>
                  </div>
                  <p class="text-background-dark/60 text-xs line-clamp-2 leading-relaxed font-sans font-light">
                    {project.description}
                  </p>
                </div>

                <!-- Button CTA -->
                <div class="flex items-center gap-2 text-primary text-[9px] font-bold uppercase tracking-[0.2em] group-hover:gap-4 transition-all mt-4">
                  <span>Explore Details</span>
                  <span class="material-icons-outlined text-xs">east</span>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Back to Home -->
      <div class="mt-24 flex justify-center border-t border-primary/10 pt-10">
        <a href="/#project" class="flex items-center gap-2 text-primary text-[10px] font-bold hover:gap-4 transition-all uppercase tracking-widest group">
          <span class="material-icons-outlined group-hover:-translate-x-1 transition-transform">west</span>
          <span>Back to Home</span>
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  function setupInteractiveExplorer() {
    const filterButtons = document.querySelectorAll(".filter-btn");
    const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
    const clearSearchBtn = document.getElementById("clear-search");
    const noResults = document.getElementById("no-results");
    const resetFiltersBtn = document.getElementById("reset-filters");
    const projectCards = document.querySelectorAll(".project-card");
    const statTotal = document.getElementById("stat-total");

    if (!searchInput || !projectCards) return;

    let activeFilter = "all";
    let searchQuery = "";

    function filterProjects() {
      let visibleCount = 0;

      projectCards.forEach((card) => {
        const cardElement = card as HTMLElement;
        const category = cardElement.dataset.category || "";
        const name = cardElement.dataset.name || "";
        const client = cardElement.dataset.client || "";
        const location = cardElement.dataset.location || "";
        const furniture = cardElement.dataset.furniture || "";

        const matchesFilter = activeFilter === "all" || category === activeFilter;
        const matchesSearch = !searchQuery || 
          name.includes(searchQuery) ||
          client.includes(searchQuery) ||
          location.includes(searchQuery) ||
          furniture.includes(searchQuery);

        if (matchesFilter && matchesSearch) {
          cardElement.classList.remove("hidden-card");
          cardElement.style.animation = 'none';
          // Trigger reflow to restart animation
          void cardElement.offsetWidth;
          cardElement.style.animation = '';
          visibleCount++;
        } else {
          cardElement.classList.add("hidden-card");
        }
      });

      // Update counters
      if (statTotal) {
        statTotal.textContent = visibleCount.toString();
      }

      // Handle No Results State
      if (visibleCount === 0) {
        noResults?.classList.remove("hidden");
      } else {
        noResults?.classList.add("hidden");
      }
    }

    // Category Filter Buttons
    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        filterButtons.forEach((b) => {
          b.classList.remove("active", "bg-primary", "text-white");
          b.classList.add("text-background-dark/70");
        });

        btn.classList.add("active", "bg-primary", "text-white");
        btn.classList.remove("text-background-dark/70");

        activeFilter = btn.getAttribute("data-filter") || "all";
        filterProjects();
      });
    });

    // Search Input
    searchInput.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement;
      searchQuery = target.value.trim().toLowerCase();

      if (searchQuery) {
        clearSearchBtn?.classList.remove("hidden");
      } else {
        clearSearchBtn?.classList.add("hidden");
      }

      filterProjects();
    });

    // Clear Search Button
    clearSearchBtn?.addEventListener("click", () => {
      searchInput.value = "";
      searchQuery = "";
      clearSearchBtn.classList.add("hidden");
      filterProjects();
    });

    // Reset Filters Button
    const resetAll = () => {
      searchInput.value = "";
      searchQuery = "";
      clearSearchBtn?.classList.add("hidden");
      
      filterButtons.forEach((btn) => {
        const filter = btn.getAttribute("data-filter");
        if (filter === "all") {
          btn.classList.add("active", "bg-primary", "text-white");
          btn.classList.remove("text-background-dark/70");
          activeFilter = "all";
        } else {
          btn.classList.remove("active", "bg-primary", "text-white");
          btn.classList.add("text-background-dark/70");
        }
      });

      filterProjects();
    };

    resetFiltersBtn?.addEventListener("click", resetAll);
  }

  // Setup on page load and navigation
  document.addEventListener("DOMContentLoaded", setupInteractiveExplorer);
  document.addEventListener("astro:page-load", setupInteractiveExplorer);
</script>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hidden-card {
    display: none !important;
  }
</style>
