---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";

export async function getStaticPaths() {
  return projects.map((project, index) => {
    const nextProject = projects[(index + 1) % projects.length];
    return {
      params: { slug: project.slug },
      props: { project, nextProjectSlug: nextProject.slug },
    };
  });
}

const { project, nextProjectSlug } = Astro.props;
---

<Layout title={`${project.name} | Sorajati Dharma Proyek`}>
  <!-- Navigation Buttons - Top Left Fixed -->
  <div class="fixed top-6 left-6 z-50 flex items-center gap-3">
    <a
      href="/#project"
      class="bg-white border border-primary/10 p-3 rounded-none shadow-md text-background-dark hover:bg-primary hover:text-white transition-all duration-300 group"
      aria-label="Back to Projects"
    >
      <span
        class="material-icons-outlined text-xl group-hover:-translate-x-1 transition-transform flex items-center justify-center"
        >arrow_back</span
      >
    </a>
    <a
      href={`/project/${nextProjectSlug}`}
      class="bg-white border border-primary/10 px-6 py-3 rounded-none shadow-md text-background-dark hover:bg-primary hover:text-white transition-all duration-300 flex items-center gap-2 group"
    >
      <span class="text-[9px] font-bold tracking-[0.2em] uppercase"
        >Next Project</span
      >
      <span
        class="material-icons-outlined text-base group-hover:translate-x-1 transition-transform flex items-center justify-center"
        >arrow_forward</span
      >
    </a>
  </div>

  <!-- Main Content Wrapper - Full Screen Split -->
  <div class="min-h-screen w-full flex flex-col lg:flex-row bg-[#FAF7F2]">
    <!-- Left: Image Slider (60% width) -->
    <div
      class="w-full lg:w-[60%] bg-white relative h-[50vh] lg:h-screen order-2 lg:order-1 border-r border-primary/10 flex items-center"
    >
      <div class="swiper detail-slider w-full h-full">
        <div class="swiper-wrapper">
          {
            project.images &&
              project.images.map((image) => (
                <div class="swiper-slide w-full h-full flex items-center justify-center p-8 lg:p-16">
                  <img
                    src={image}
                    alt={project.name}
                    class="w-auto h-auto max-w-full max-h-full object-contain shadow-sm border border-primary/5 p-2 bg-white"
                  />
                </div>
              ))
          }
          {
            !project.images && (
              <div class="swiper-slide w-full h-full flex items-center justify-center p-8 lg:p-16">
                <img
                  src={project.img}
                  alt={project.name}
                  class="w-auto h-auto max-w-full max-h-full object-contain shadow-sm border border-primary/5 p-2 bg-white"
                />
              </div>
            )
          }
        </div>
        <!-- Slider Navigation -->
        <div
          class="swiper-button-prev !text-primary bg-white/80 border border-primary/10 p-6 rounded-none hover:bg-primary hover:text-white transition-all shadow-md left-4 lg:left-8 flex items-center justify-center group"
        >
          <span
            class="material-icons-outlined text-lg group-hover:scale-110 transition-transform"
            >keyboard_arrow_left</span
          >
        </div>
        <div
          class="swiper-button-next !text-primary bg-white/80 border border-primary/10 p-6 rounded-none hover:bg-primary hover:text-white transition-all shadow-md right-4 lg:right-8 flex items-center justify-center group"
        >
          <span
            class="material-icons-outlined text-lg group-hover:scale-110 transition-transform"
            >keyboard_arrow_right</span
          >
        </div>
      </div>
    </div>

    <!-- Right: Project Details (40% width) -->
    <div
      class="w-full lg:w-[40%] bg-[#FAF7F2] text-background-dark h-auto lg:h-screen lg:overflow-y-auto order-1 lg:order-2 flex items-center"
    >
      <div class="p-8 lg:p-16 flex flex-col min-h-full justify-center w-full">
        <!-- Header -->
        <div class="mb-12 border-b border-primary/10 pb-8">
          <span class="text-primary text-[10px] font-bold tracking-[0.3em] uppercase block mb-2">Installation</span>
          <h1 class="font-display text-4xl lg:text-5xl font-bold tracking-tight text-background-dark uppercase leading-tight">
            {project.name}
          </h1>
        </div>

        <!-- Details -->
        <div class="space-y-8">
          <div>
            <h2
              class="text-[9px] font-bold uppercase tracking-[0.2em] text-primary/75 mb-3"
            >
              Description
            </h2>
            <p
              class="text-xs md:text-sm leading-relaxed text-background-dark/80 font-sans font-light text-justify"
            >
              {project.description}
            </p>
          </div>

          <div>
            <h2
              class="text-[9px] font-bold uppercase tracking-[0.2em] text-primary/75 mb-3"
            >
              Furniture Supplied
            </h2>
            <ul class="grid grid-cols-1 gap-2.5">
              {
                project.furniture.map((item) => (
                  <li class="flex items-start text-xs text-background-dark/85 font-medium leading-relaxed">
                    <span class="w-1.5 h-1.5 border border-primary/30 bg-primary/10 rounded-none mr-2.5 mt-1.5 flex-shrink-0" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Project Specs -->
        <div
          class="grid grid-cols-2 gap-y-6 gap-x-4 mt-12 pt-8 border-t border-primary/10"
        >
          <div>
            <h4
              class="text-[9px] font-bold text-background-dark/40 uppercase tracking-widest mb-1"
            >
              Year Completed
            </h4>
            <p class="text-sm font-bold text-background-dark font-display">{project.year}</p>
          </div>
          <div>
            <h4
              class="text-[9px] font-bold text-background-dark/40 uppercase tracking-widest mb-1"
            >
              Client
            </h4>
            <p class="text-sm font-bold text-background-dark uppercase font-display">
              {project.client}
            </p>
          </div>
        </div>

        <!-- Direct WhatsApp Inquiry -->
        <div class="mt-12">
          <a
            href={`https://wa.me/81128507788?text=Hello%20Sorajati%20Dharma,%20I'm%20inquiring%20about%20the%20furniture%20supplied%20for%20project%20${encodeURIComponent(project.name)}.`}
            target="_blank"
            class="block w-full text-center bg-primary text-white py-4 text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-primary/95 transition-colors shadow-sm"
          >
            Inquire About This Design
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import Swiper from "swiper";
  import { Navigation, Autoplay, EffectFade } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/navigation";
  import "swiper/css/effect-fade";

  const initSwiper = () => {
    new Swiper(".detail-slider", {
      modules: [Navigation, Autoplay, EffectFade],
      effect: "fade",
      fadeEffect: {
        crossFade: true,
      },
      loop: true,
      observer: true,
      observeParents: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
      },
    });
  };

  document.addEventListener("astro:page-load", initSwiper);
  document.addEventListener("DOMContentLoaded", initSwiper);
</script>

<style>
  .swiper-button-next::after,
  .swiper-button-prev::after {
    display: none !important;
  }
</style>
