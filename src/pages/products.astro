---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { productCategories } from "../data/products";

// Extract unique categories for the filter
const categories = ["ALL", "Sofa", "Chair", "Table", "Bench", "Accessories"];
const allProducts = productCategories.flatMap((cat) => cat.items);
---

<Layout title="Sorajati Dharma Products | Our Collection">
  <Navbar />
  <main class="pt-36 pb-24 bg-background-light min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
      
      <!-- Section Header -->
      <div class="mb-16 text-center max-w-2xl mx-auto">
        <span class="text-primary text-[10px] font-bold tracking-[0.3em] uppercase block mb-3">Sorajati Dharma Collections</span>
        <h1 class="font-display text-4xl md:text-6xl text-background-dark leading-tight mb-6">
          Exotic Wood <span class="font-serif italic text-primary">Catalog</span>
        </h1>
        <p class="text-background-dark/70 text-xs md:text-sm leading-relaxed font-sans font-light">
          Explore our complete range of premium handcrafted furniture, engineered for luxury comfort and architectural durability.
        </p>
      </div>

      <!-- Filter Buttons -->
      <div class="flex flex-wrap justify-center gap-3 mb-16" id="filter-container">
        {
          categories.map((category) => (
            <button
              class={`filter-btn px-6 py-2.5 border text-[10px] font-bold tracking-[0.2em] uppercase transition-all duration-300 ${
                category === "ALL"
                  ? "bg-primary text-white border-primary"
                  : "bg-white text-primary border-primary/10 hover:border-primary"
              }`}
              data-category={category}
            >
              {category}
            </button>
          ))
        }
      </div>

      <!-- Product Grid -->
      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8"
        id="product-grid"
      >
        {
          allProducts.map((item) => (
            <div
              class="group cursor-pointer product-item transition-all duration-500 animate-fade-in"
              data-product={JSON.stringify(item)}
              data-category={item.category}
            >
              <div class="aspect-[4/5] bg-white border border-primary/10 p-6 flex items-center justify-center relative overflow-hidden mb-4 shadow-sm group-hover:shadow-md transition-shadow">
                <img
                  src={item.img}
                  alt={item.name}
                  class="max-w-full max-h-full object-contain transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                  <span class="bg-white text-primary px-4 py-2 text-[9px] font-bold tracking-[0.25em] uppercase border border-primary/15 shadow-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                    Quick View
                  </span>
                </div>
              </div>
              <div class="text-center">
                <span class="block text-[9px] uppercase tracking-widest text-primary/60 font-semibold mb-1">{item.category}</span>
                <h4 class="font-display text-sm font-bold text-background-dark tracking-wider">{item.name}</h4>
                <span class="block text-[10px] font-mono text-background-dark/50 mt-1">[{item.id}]</span>
              </div>
            </div>
          ))
        }
      </div>
      
       <!-- Back to Home -->
       <div class="mt-24 flex justify-center border-t border-primary/10 pt-10">
        <a href="/#home" class="flex items-center gap-2 text-primary text-[10px] font-bold hover:gap-4 transition-all uppercase tracking-widest group">
          <span class="material-icons-outlined group-hover:-translate-x-1 transition-transform">west</span>
          <span>Back to Home</span>
        </a>
      </div>

    </div>

    <!-- Product Modal -->
    <div
      id="product-modal"
      class="fixed inset-0 z-[100] hidden items-center justify-center p-4 lg:p-8"
    >
      <div
        class="absolute inset-0 bg-background-dark/85 backdrop-blur-sm transition-opacity duration-300"
        id="modal-backdrop"
      >
      </div>
      <div
        class="relative bg-[#FAF7F2] w-full max-w-5xl border border-primary/15 shadow-2xl overflow-hidden flex flex-col md:flex-row transform transition-all scale-95 opacity-0 max-h-[95vh] md:max-h-[90vh]"
        id="modal-content"
      >
        <!-- Close Button -->
        <button
          id="modal-close"
          class="absolute top-4 right-4 z-[110] p-2 text-background-dark/50 hover:text-red-500 transition-colors bg-white/80 border border-primary/10 rounded-none shadow-sm"
        >
          <span class="material-icons-outlined text-xl">close</span>
        </button>

        <!-- Product Image (Left) -->
        <div class="w-full md:w-1/2 bg-white p-6 md:p-8 flex items-center justify-center border-r border-primary/10 min-h-[300px] md:min-h-[500px]">
          <div class="w-full aspect-[4/3] md:aspect-square flex items-center justify-center relative overflow-hidden bg-zinc-50 border border-primary/5 p-4">
            <img
              id="modal-main-img"
              src=""
              alt=""
              class="max-w-full max-h-full w-auto h-auto object-contain mx-auto transition-all duration-300"
            />
          </div>
        </div>

        <!-- Description (Right) -->
        <div class="w-full md:w-1/2 p-6 md:p-12 flex flex-col justify-between overflow-y-auto bg-[#FAF7F2]">
          <div>
            <!-- Title & Subtitle Container (Right-aligned) -->
            <div class="text-right mb-8">
              <h3
                id="modal-title"
                class="font-display text-4xl md:text-5xl font-bold text-[#4A3B32] uppercase leading-tight tracking-wide"
              >
              </h3>
              <p
                id="modal-subtitle"
                class="text-[#4A3B32]/70 text-sm md:text-base font-sans tracking-wide mt-2"
              >
              </p>
            </div>
            
            <!-- Specs Container (Left-aligned) -->
            <div class="space-y-6 text-left">
              <div>
                <h4 id="modal-spec-label" class="font-bold text-xs uppercase tracking-widest text-[#4A3B32] border-b border-[#4A3B32]/20 pb-1 inline-block mb-3">
                  Dimension :
                </h4>
                <div
                  id="modal-dimensions"
                  class="text-xs md:text-sm text-background-dark/80 leading-relaxed font-sans font-light whitespace-pre-line"
                ></div>
              </div>
              
              <div>
                <h4 class="font-bold text-xs uppercase tracking-widest text-[#4A3B32] border-b border-[#4A3B32]/20 pb-1 inline-block mb-3">
                  Code :
                </h4>
                <div
                  id="modal-code"
                  class="text-xs md:text-sm text-background-dark/80 font-mono tracking-wider font-light"
                ></div>
              </div>

              <div id="modal-finishes-section">
                <h4 class="font-bold text-xs uppercase tracking-widest text-[#4A3B32] mb-3 block">
                  Available in :
                </h4>
                <div
                  id="modal-finishes-wrapper"
                  class="flex flex-wrap gap-2.5"
                ></div>
              </div>

              <div id="modal-detail-section">
                <h4 class="font-bold text-xs uppercase tracking-widest text-[#4A3B32] mb-3 block">
                  Detail :
                </h4>
                <div
                  id="modal-detail-wrapper"
                  class="flex flex-wrap gap-3"
                ></div>
              </div>
            </div>
          </div>

          <!-- Inquire CTA -->
          <div class="mt-8 pt-6 border-t border-primary/10">
            <a
              id="modal-inquire-btn"
              href="#"
              target="_blank"
              class="w-full text-center block bg-[#4A3B32] text-white py-4 text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#3d3129] transition-colors"
            >
              Send Inquiry via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import Swiper from "swiper";
  import { Navigation, Thumbs, EffectFade } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/navigation";
  import "swiper/css/thumbs";
  import "swiper/css/effect-fade";

  function initPage() {
    // --- Filter Logic ---
    const filterBtns = document.querySelectorAll(".filter-btn");
    const productItems = document.querySelectorAll(".product-item");

    function filterProducts(category: string) {
      // Update buttons
      filterBtns.forEach((btn) => {
        if (btn instanceof HTMLElement) {
          if (btn.dataset.category === category) {
            btn.classList.add("bg-primary", "text-white", "border-primary");
            btn.classList.remove("bg-white", "text-primary", "border-primary/10");
          } else {
            btn.classList.remove("bg-primary", "text-white", "border-primary");
            btn.classList.add("bg-white", "text-primary", "border-primary/10");
          }
        }
      });

      // Filter grid
      productItems.forEach((item) => {
        if (item instanceof HTMLElement) {
          const itemCategory = item.dataset.category;
          if (category === "ALL" || itemCategory === category) {
            item.style.display = "";
            item.classList.add("animate-fade-in");
          } else {
            item.style.display = "none";
            item.classList.remove("animate-fade-in");
          }
        }
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn instanceof HTMLElement) {
          const category = btn.dataset.category || "ALL";
          filterProducts(category);
        }
      });
    });

    // Check for category in URL query params
    const urlParams = new URLSearchParams(window.location.search);
    const initialCategory = urlParams.get("category") || "ALL";
    filterProducts(initialCategory);
    // --- Modal Logic ---
    const modal = document.getElementById("product-modal");
    const modalContent = document.getElementById("modal-content");
    const modalBackdrop = document.getElementById("modal-backdrop");
    const modalClose = document.getElementById("modal-close");

    const modalTitle = document.getElementById("modal-title");
    const modalSubtitle = document.getElementById("modal-subtitle");
    const modalSpecLabel = document.getElementById("modal-spec-label");
    const modalDims = document.getElementById("modal-dimensions");
    const modalCode = document.getElementById("modal-code");
    const modalInquire = document.getElementById("modal-inquire-btn");
    const mainImg = document.getElementById("modal-main-img");
    const detailWrapper = document.getElementById("modal-detail-wrapper");
    const detailSection = document.getElementById("modal-detail-section");
    const modalFinishesSection = document.getElementById("modal-finishes-section");
    const modalFinishesWrapper = document.getElementById("modal-finishes-wrapper");

    function openModal() {
      if (!modal) return;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      setTimeout(() => {
        modalContent?.classList.remove("scale-95", "opacity-0");
        modalContent?.classList.add("scale-100", "opacity-100");
      }, 10);
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modalContent?.classList.remove("scale-100", "opacity-100");
      modalContent?.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
      }, 300);
      document.body.style.overflow = "";
    }

    modalClose?.addEventListener("click", closeModal);
    modalBackdrop?.addEventListener("click", closeModal);

    productItems.forEach((item) => {
      item.addEventListener("click", () => {
        try {
          const productData = item.getAttribute("data-product");
          if (!productData) return;
          const data = JSON.parse(productData);

          const name = data.name || "Unnamed Product";
          const id = data.id || "N/A";
          const category = data.category || "Collection";
          const dimensions = data.dimensions || "Custom dimensions available upon request";

          // Format Title & Subtitle based on spacing
          let title = name;
          let subtitle = category + " Collection";
          const words = name.split(" ");
          if (words.length > 1) {
            title = words[0];
            subtitle = words.slice(1).join(" ");
          }

          if (modalTitle) {
            modalTitle.textContent = title;
          }
          if (modalSubtitle) {
            modalSubtitle.textContent = subtitle;
          }

          // Handle Specification vs Dimension Label
          if (modalSpecLabel) {
            if (data.specification) {
              modalSpecLabel.textContent = "Specification :";
              if (modalDims) {
                modalDims.innerHTML = data.specification.replace(/\n/g, "<br />");
              }
            } else {
              modalSpecLabel.textContent = "Dimension :";
              if (modalDims) {
                modalDims.innerHTML = dimensions.replace(/\n/g, "<br />");
              }
            }
          }

          // Format Code
          let code = data.code;
          if (!code) {
            const prefix = category.substring(0, 4).toUpperCase();
            code = `${prefix} - TK - ${id}`;
          }
          if (modalCode) {
            modalCode.textContent = code;
          }

          // Set Main Image
          if (mainImg) {
            mainImg.setAttribute("src", data.img || "/images/logo-kjas.svg");
            mainImg.setAttribute("alt", name);
          }

          // Render finishes if available
          if (modalFinishesSection && modalFinishesWrapper) {
            if (data.finishes && data.finishes.length > 0) {
              modalFinishesSection.style.display = "block";
              modalFinishesWrapper.innerHTML = "";
              data.finishes.forEach((color) => {
                const swatch = document.createElement("div");
                swatch.className = "w-10 h-10 border border-[#4A3B32]/15 hover:scale-105 transition-transform cursor-pointer";
                swatch.style.backgroundColor = color;
                modalFinishesWrapper.appendChild(swatch);
              });
            } else {
              modalFinishesSection.style.display = "none";
            }
          }

          // Render detail thumbnails
          const images = data.detailImages && data.detailImages.length > 0 ? data.detailImages : [data.img];
          if (detailWrapper && detailSection) {
            detailWrapper.innerHTML = "";
            
            // Render small image thumbnails
            images.forEach((src) => {
              const thumb = document.createElement("img");
              thumb.src = src;
              thumb.alt = "Detail variant thumbnail";
              thumb.className = "w-16 h-16 object-contain bg-white border border-[#4A3B32]/10 hover:border-[#4A3B32] p-1 cursor-pointer transition-all";
              thumb.addEventListener("click", () => {
                if (mainImg) {
                  mainImg.setAttribute("src", src);
                }
              });
              detailWrapper.appendChild(thumb);
            });
          }

          // WhatsApp Inquiry Link
          if (modalInquire) {
            const message = `Hello Sorajati Dharma, I would like to inquire about this product:\n\nName: ${name}\nCode: ${code}\nCategory: ${category}\nDimensions:\n${dimensions}`;
            modalInquire.setAttribute("href", `https://wa.me/6285866005019?text=${encodeURIComponent(message)}`);
          }

          openModal();
        } catch (err) {
          console.error("Error opening modal:", err);
        }
      });
    });
  }

  // Run on initial load and navigation
  document.addEventListener("astro:page-load", initPage);
</script>

<style>
  .swiper-button-next::after,
  .swiper-button-prev::after {
    content: none !important;
  }
  :global(.modal-thumbs .swiper-slide-thumb-active) {
    border-color: #173B21 !important;
    opacity: 1;
  }
  :global(.modal-thumbs .swiper-slide) {
    opacity: 0.5;
  }
  :global(.modal-thumbs .swiper-slide:hover) {
    opacity: 1;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>
