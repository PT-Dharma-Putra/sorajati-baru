---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { productCategories } from "../data/products";

// Extract unique categories for the filter
const categories = ["ALL", "Sofa", "Chair", "Table", "Bench", "Accessories"];
const allProducts = productCategories.flatMap((cat) => cat.items);
---

<Layout title="Sorajati Dharma Products | Our Collection">
  <Navbar />
  <main class="pt-36 pb-24 bg-background-light min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
      
      <!-- Section Header -->
      <div class="mb-16 text-center max-w-2xl mx-auto">
        <span class="text-primary text-[10px] font-bold tracking-[0.3em] uppercase block mb-3">Sorajati Dharma Collections</span>
        <h1 class="font-display text-4xl md:text-6xl text-background-dark leading-tight mb-6">
          Exotic Wood <span class="font-serif italic text-primary">Catalog</span>
        </h1>
        <p class="text-background-dark/70 text-xs md:text-sm leading-relaxed font-sans font-light">
          Explore our complete range of premium handcrafted furniture, engineered for luxury comfort and architectural durability.
        </p>
      </div>

      <!-- Filter Buttons -->
      <div class="flex flex-wrap justify-center gap-3 mb-16" id="filter-container">
        {
          categories.map((category) => (
            <button
              class={`filter-btn px-6 py-2.5 border text-[10px] font-bold tracking-[0.2em] uppercase transition-all duration-300 ${
                category === "ALL"
                  ? "bg-primary text-white border-primary"
                  : "bg-white text-primary border-primary/10 hover:border-primary"
              }`}
              data-category={category}
            >
              {category}
            </button>
          ))
        }
      </div>

      <!-- Product Grid -->
      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8"
        id="product-grid"
      >
        {
          allProducts.map((item) => (
            <div
              class="group cursor-pointer product-item transition-all duration-500 animate-fade-in"
              data-product={JSON.stringify(item)}
              data-category={item.category}
            >
              <div class="aspect-[4/5] bg-white border border-primary/10 p-6 flex items-center justify-center relative overflow-hidden mb-4 shadow-sm group-hover:shadow-md transition-shadow">
                <img
                  src={item.img}
                  alt={item.name}
                  class="max-w-full max-h-full object-contain transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                  <span class="bg-white text-primary px-4 py-2 text-[9px] font-bold tracking-[0.25em] uppercase border border-primary/15 shadow-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                    Quick View
                  </span>
                </div>
              </div>
              <div class="text-center">
                <span class="block text-[9px] uppercase tracking-widest text-primary/60 font-semibold mb-1">{item.category}</span>
                <h4 class="font-display text-sm font-bold text-background-dark tracking-wider">{item.name}</h4>
                <span class="block text-[10px] font-mono text-background-dark/50 mt-1">[{item.id}]</span>
              </div>
            </div>
          ))
        }
      </div>
      
       <!-- Back to Home -->
       <div class="mt-24 flex justify-center border-t border-primary/10 pt-10">
        <a href="/#home" class="flex items-center gap-2 text-primary text-[10px] font-bold hover:gap-4 transition-all uppercase tracking-widest group">
          <span class="material-icons-outlined group-hover:-translate-x-1 transition-transform">west</span>
          <span>Back to Home</span>
        </a>
      </div>

    </div>

    <!-- Product Modal -->
    <div
      id="product-modal"
      class="fixed inset-0 z-[100] hidden items-center justify-center p-4 lg:p-8"
    >
      <div
        class="absolute inset-0 bg-background-dark/85 backdrop-blur-sm transition-opacity duration-300"
        id="modal-backdrop"
      >
      </div>
      <div
        class="relative bg-[#FAF7F2] w-full max-w-5xl border border-primary/15 shadow-2xl overflow-hidden flex flex-col md:flex-row transform transition-all scale-95 opacity-0 max-h-[95vh] md:max-h-[90vh]"
        id="modal-content"
      >
        <!-- Close Button -->
        <button
          id="modal-close"
          class="absolute top-4 right-4 z-[110] p-2 text-background-dark/50 hover:text-red-500 transition-colors bg-white/80 border border-primary/10 rounded-none shadow-sm"
        >
          <span class="material-icons-outlined text-xl">close</span>
        </button>

        <!-- Gallery (Left) -->
        <div class="w-full md:w-1/2 bg-white p-6 md:p-8 flex flex-col gap-6 overflow-y-auto border-r border-primary/10">
          <div class="swiper modal-gallery w-full aspect-square overflow-hidden bg-zinc-50 border border-primary/5">
            <div class="swiper-wrapper" id="modal-gallery-wrapper"></div>
            <div class="swiper-button-prev !text-primary after:!text-xl bg-white/80 p-5 rounded-none border border-primary/10 shadow-sm hover:bg-white transition-colors"></div>
            <div class="swiper-button-next !text-primary after:!text-xl bg-white/80 p-5 rounded-none border border-primary/10 shadow-sm hover:bg-white transition-colors"></div>
          </div>
          <div class="swiper modal-thumbs w-full h-16 p-1">
            <div class="swiper-wrapper" id="modal-thumbs-wrapper"></div>
          </div>
        </div>

        <!-- Description (Right) -->
        <div class="w-full md:w-1/2 p-6 md:p-12 flex flex-col justify-between overflow-y-auto bg-[#FAF7F2]">
          <div>
            <div id="modal-category-badge" class="mb-4"></div>
            <h3
              id="modal-title"
              class="font-display text-2xl md:text-4xl font-bold text-background-dark mb-6 leading-tight"
            >
            </h3>
            
            <div class="space-y-6">
              <div class="border-b border-primary/10 pb-6">
                <p class="text-[9px] uppercase tracking-widest text-primary/60 font-bold mb-2">Description</p>
                <p
                  id="modal-description"
                  class="text-xs md:text-sm text-background-dark/80 leading-relaxed font-sans font-light"
                ></p>
              </div>
              <div>
                <p class="text-[9px] uppercase tracking-widest text-primary/60 font-bold mb-2">Dimensions</p>
                <p id="modal-dimensions" class="text-sm md:text-base font-display text-background-dark font-semibold"></p>
              </div>
            </div>
          </div>

          <!-- Inquire CTA -->
          <div class="mt-8 pt-6 border-t border-primary/10">
            <a
              id="modal-inquire-btn"
              href="#"
              target="_blank"
              class="w-full text-center block bg-primary text-white py-4 text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-primary/95 transition-colors"
            >
              Send Inquiry via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import Swiper from "swiper";
  import { Navigation, Thumbs, EffectFade } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/navigation";
  import "swiper/css/thumbs";
  import "swiper/css/effect-fade";

  function initPage() {
    // --- Filter Logic ---
    const filterBtns = document.querySelectorAll(".filter-btn");
    const productItems = document.querySelectorAll(".product-item");

    function filterProducts(category: string) {
      // Update buttons
      filterBtns.forEach((btn) => {
        if (btn instanceof HTMLElement) {
          if (btn.dataset.category === category) {
            btn.classList.add("bg-primary", "text-white", "border-primary");
            btn.classList.remove("bg-white", "text-primary", "border-primary/10");
          } else {
            btn.classList.remove("bg-primary", "text-white", "border-primary");
            btn.classList.add("bg-white", "text-primary", "border-primary/10");
          }
        }
      });

      // Filter grid
      productItems.forEach((item) => {
        if (item instanceof HTMLElement) {
          const itemCategory = item.dataset.category;
          if (category === "ALL" || itemCategory === category) {
            item.style.display = "";
            item.classList.add("animate-fade-in");
          } else {
            item.style.display = "none";
            item.classList.remove("animate-fade-in");
          }
        }
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn instanceof HTMLElement) {
          const category = btn.dataset.category || "ALL";
          filterProducts(category);
        }
      });
    });

    // Check for category in URL query params
    const urlParams = new URLSearchParams(window.location.search);
    const initialCategory = urlParams.get("category") || "ALL";
    filterProducts(initialCategory);

    // --- Modal Logic ---
    const modal = document.getElementById("product-modal");
    const modalContent = document.getElementById("modal-content");
    const modalBackdrop = document.getElementById("modal-backdrop");
    const modalClose = document.getElementById("modal-close");

    const modalTitle = document.getElementById("modal-title");
    const modalBadge = document.getElementById("modal-category-badge");
    const modalDesc = document.getElementById("modal-description");
    const modalDims = document.getElementById("modal-dimensions");
    const modalInquire = document.getElementById("modal-inquire-btn");
    const galleryWrapper = document.getElementById("modal-gallery-wrapper");
    const thumbsWrapper = document.getElementById("modal-thumbs-wrapper");

    let gallerySwiper: any = null;
    let thumbsSwiper: any = null;

    function openModal() {
      if (!modal) return;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      setTimeout(() => {
        modalContent?.classList.remove("scale-95", "opacity-0");
        modalContent?.classList.add("scale-100", "opacity-100");
      }, 10);
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modalContent?.classList.remove("scale-100", "opacity-100");
      modalContent?.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
      }, 300);
      document.body.style.overflow = "";
    }

    modalClose?.addEventListener("click", closeModal);
    modalBackdrop?.addEventListener("click", closeModal);

    productItems.forEach((item) => {
      item.addEventListener("click", () => {
        try {
          const productData = item.getAttribute("data-product");
          if (!productData) return;
          const data = JSON.parse(productData);

          const name = data.name || "Unnamed Product";
          const id = data.id || "N/A";
          const category = data.category || "Collection";
          const description = data.description || "Crafted with premium materials to ensure lasting comfort and timeless elegance for your space.";
          const dimensions = data.dimensions || "Custom dimensions available upon request";

          // Populate Texts
          if (modalBadge) {
            modalBadge.innerHTML = `<span class="inline-block border border-primary/20 text-primary px-3 py-1 text-[9px] font-bold tracking-[0.2em] uppercase bg-white">${category}</span>`;
          }
          if (modalTitle) {
            modalTitle.textContent = `${name}`;
          }
          if (modalDesc) {
            modalDesc.textContent = description;
          }
          if (modalDims) {
            modalDims.textContent = dimensions;
          }

          // WhatsApp Inquiry Link
          if (modalInquire) {
            const message = `Hello Sorajati Dharma, I would like to inquire about this product:\n\nName: ${name}\nID: ${id}\nCategory: ${category}\nDimensions: ${dimensions}`;
            modalInquire.setAttribute("href", `https://wa.me/81128507788?text=${encodeURIComponent(message)}`);
          }

          // Populate Images
          const images = data.detailImages && data.detailImages.length > 0 ? data.detailImages : [data.img || "/images/logo-kjas.svg"];

          if (galleryWrapper && thumbsWrapper) {
            galleryWrapper.innerHTML = images
              .map(
                (src: string) =>
                  `<div class="swiper-slide bg-white flex items-center justify-center p-4 h-full"><img src="${src}" class="max-w-full max-h-full w-auto h-auto object-contain mx-auto" loading="lazy" /></div>`,
              )
              .join("");

            thumbsWrapper.innerHTML = images
              .map(
                (src: string) =>
                  `<div class="swiper-slide cursor-pointer border border-primary/10 overflow-hidden transition-all hover:border-primary flex items-center justify-center h-full bg-white"><img src="${src}" class="w-full h-full object-cover" loading="lazy" /></div>`,
              )
              .join("");
          }

          // Destroy previous swipers
          gallerySwiper?.destroy?.();
          thumbsSwiper?.destroy?.();

          // Initialize Thumbs Swiper
          thumbsSwiper = new Swiper(".modal-thumbs", {
            modules: [Navigation, Thumbs],
            spaceBetween: 8,
            slidesPerView: 4,
            freeMode: true,
            watchSlidesProgress: true,
          });

          // Initialize Gallery Swiper
          gallerySwiper = new Swiper(".modal-gallery", {
            modules: [Navigation, Thumbs, EffectFade],
            loop: images.length > 1,
            effect: "fade",
            fadeEffect: { crossFade: true },
            spaceBetween: 10,
            navigation: {
              nextEl: ".modal-gallery .swiper-button-next",
              prevEl: ".modal-gallery .swiper-button-prev",
            },
            thumbs: {
              swiper: thumbsSwiper,
            },
          });

          openModal();
        } catch (err) {
          console.error("Error opening modal:", err);
        }
      });
    });
  }

  // Run on initial load and navigation
  document.addEventListener("astro:page-load", initPage);
</script>

<style>
  .swiper-button-next::after,
  .swiper-button-prev::after {
    content: none !important;
  }
  :global(.modal-thumbs .swiper-slide-thumb-active) {
    border-color: #173B21 !important;
    opacity: 1;
  }
  :global(.modal-thumbs .swiper-slide) {
    opacity: 0.5;
  }
  :global(.modal-thumbs .swiper-slide:hover) {
    opacity: 1;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>
