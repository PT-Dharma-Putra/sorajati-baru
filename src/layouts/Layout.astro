---
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html class="scroll-smooth overflow-x-hidden" lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/images/logo-sora.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Sorajati Dharma Furniture | Luxury Earthy Elegance</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Arsenal:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&family=Material+Icons+Outlined&family=Great+Vibes&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body
    class="bg-background-light text-background-dark font-sans overflow-x-hidden"
  >
    <div id="scroll-progress" class="fixed top-0 left-0 h-[3px] bg-gradient-to-r from-primary to-secondary z-[999] transition-all duration-100" style="width: 0%"></div>
    <div id="custom-cursor-dot" class="fixed w-2 h-2 bg-secondary rounded-full pointer-events-none z-[9999] opacity-0 transition-opacity duration-300 hidden md:block mix-blend-difference"></div>
    <div id="custom-cursor-outline" class="fixed w-8 h-8 border border-secondary/50 rounded-full pointer-events-none z-[9998] opacity-0 transition-all duration-300 ease-out -translate-x-1/2 -translate-y-1/2 hidden md:block mix-blend-difference"></div>
    <main id="main-content">
      <slot />
    </main>

    <style is:global>
      /* Base reveal states */
      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: transform, opacity;
      }

      .reveal.active {
        opacity: 1;
        transform: translateY(0);
      }

      /* Staggered entrance helpers */
      .stagger-1 {
        transition-delay: 0.1s;
      }
      .stagger-2 {
        transition-delay: 0.2s;
      }
      .stagger-3 {
        transition-delay: 0.3s;
      }
      .stagger-4 {
        transition-delay: 0.4s;
      }
    </style>

    <script>
      // Scroll Reveal logic
      function initReveal() {
        const observerOptions = {
          root: null,
          rootMargin: "0px",
          threshold: 0.05,
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              // Once animated, we can stop observing it
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document
          .querySelectorAll(".reveal")
          .forEach((el) => observer.observe(el));
      }

      // Preload watermark logo
      const logoImg = new Image();
      logoImg.src = "/images/logo-sora.svg";
      logoImg.crossOrigin = "anonymous";

      // Watermark function applied on right-click save
      function applyWatermark(img) {
        if (!img || !(img instanceof HTMLImageElement)) return;
        if (img.dataset.hasWatermark === "true" || img.src.startsWith("data:")) return;

        // Skip tiny images like icons, swatches, and skip logos
        if (img.naturalWidth < 120 || img.naturalHeight < 120) return;
        if (img.src.toLowerCase().includes("logo")) return;

        try {
          const canvas = document.createElement("canvas");
          const ctx = canvas.getContext("2d");
          canvas.width = img.naturalWidth || img.width;
          canvas.height = img.naturalHeight || img.height;

          // Draw original image
          ctx.drawImage(img, 0, 0);

          // Draw logo in the bottom right corner
          if (logoImg.complete && logoImg.naturalWidth > 0) {
            const logoWidth = canvas.width * 0.15;
            const logoHeight = (logoImg.naturalHeight / logoImg.naturalWidth) * logoWidth;
            const padding = canvas.width * 0.02;

            ctx.save();
            ctx.globalAlpha = 0.85; // subtle watermark transparency
            ctx.drawImage(
              logoImg,
              canvas.width - logoWidth - padding,
              canvas.height - logoHeight - padding,
              logoWidth,
              logoHeight
            );

            // Draw company name next to the logo
            ctx.font = `bold ${Math.max(12, Math.floor(canvas.width * 0.022))}px sans-serif`;
            ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
            ctx.shadowColor = "rgba(0, 0, 0, 0.7)";
            ctx.shadowBlur = 4;
            ctx.textAlign = "right";
            ctx.textBaseline = "middle";
            const textX = canvas.width - logoWidth - padding - 12;
            const textY = canvas.height - (logoHeight / 2) - padding;
            ctx.fillText("PT. Sorajati Dharma", textX, textY);
            ctx.restore();
          }

          const isPng = img.src.toLowerCase().split("?")[0].endsWith(".png");
          const watermarkedUrl = canvas.toDataURL(
            isPng ? "image/png" : "image/jpeg",
            isPng ? 1.0 : 0.9
          );

          const originalSrc = img.src;
          img.dataset.originalSrc = originalSrc;
          img.src = watermarkedUrl;
          img.dataset.hasWatermark = "true";

          // Restore original src after 1 second so the web preview remains clean
          setTimeout(() => {
            if (img.dataset.hasWatermark === "true") {
              img.src = img.dataset.originalSrc;
              img.dataset.hasWatermark = "false";
            }
          }, 1000);
        } catch (e) {
          console.error("Error applying watermark:", e);
        }
      }

      const initWatermarkListener = () => {
        // Intercept right-clicks (mousedown and contextmenu) to apply watermark
        document.addEventListener("mousedown", (e) => {
          if (e.button === 2 && e.target instanceof HTMLImageElement) {
            applyWatermark(e.target);
          }
        }, { capture: true, passive: true });

        document.addEventListener("contextmenu", (e) => {
          if (e.target instanceof HTMLImageElement) {
            applyWatermark(e.target);
          }
        }, { capture: true });
      };

      function initInteractivePremium() {
        const dot = document.getElementById("custom-cursor-dot");
        const outline = document.getElementById("custom-cursor-outline");
        const scrollBar = document.getElementById("scroll-progress");

        if (!dot || !outline) return;

        let mouseX = 0, mouseY = 0;
        let outlineX = 0, outlineY = 0;

        // Mouse Move Event
        window.addEventListener("mousemove", (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          
          dot.style.opacity = "1";
          outline.style.opacity = "1";
          
          dot.style.left = `${mouseX}px`;
          dot.style.top = `${mouseY}px`;
        });

        // Animation Loop for Smooth Trailing Effect
        const animateCursor = () => {
          const dx = mouseX - outlineX;
          const dy = mouseY - outlineY;
          
          outlineX += dx * 0.15;
          outlineY += dy * 0.15;
          
          outline.style.left = `${outlineX}px`;
          outline.style.top = `${outlineY}px`;
          
          requestAnimationFrame(animateCursor);
        };
        requestAnimationFrame(animateCursor);

        // Hover Effect on clickable elements
        const addHoverEvents = () => {
          const clickables = document.querySelectorAll("a, button, [role='button'], .product-card-item, .filter-tab-btn");
          clickables.forEach((el) => {
            el.addEventListener("mouseenter", () => {
              dot.classList.add("scale-[2.5]", "bg-secondary");
              outline.classList.add("scale-[1.8]", "border-secondary");
            });
            el.addEventListener("mouseleave", () => {
              dot.classList.remove("scale-[2.5]", "bg-secondary");
              outline.classList.remove("scale-[1.8]", "border-secondary");
            });
          });
        };
        addHoverEvents();

        // Scroll Progress
        window.addEventListener("scroll", () => {
          const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
          const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          const scrolled = (winScroll / height) * 100;
          if (scrollBar) {
            scrollBar.style.width = `${scrolled}%`;
          }
        });
        
        // Hide cursor when leaving window
        document.addEventListener("mouseleave", () => {
          dot.style.opacity = "0";
          outline.style.opacity = "0";
        });
      }

      const init = () => {
        initReveal();
        initInteractivePremium();
        initWatermarkListener();
      };

      window.addEventListener("load", init);
      document.addEventListener("astro:page-load", init);
    </script>
  </body>
</html>
